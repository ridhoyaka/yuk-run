# Salin file ini menjadi .env lalu isi nilainya
# cp .env.example .env  (Linux/Mac)
# copy .env.example .env  (Windows)

PORT=3000

# Supabase PostgreSQL Connection String
# Dapatkan dari: Supabase Dashboard → Project → Settings → Database → Connection string → URI
# Pilih mode "Transaction" (port 6543) untuk production, atau "Session" (port 5432) untuk development
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# Secret key untuk JWT (isi dengan string random yang panjang)
JWT_SECRET=ganti_dengan_secret_key_yang_kuat_dan_panjang

# Mapbox Access Token (dapatkan di https://account.mapbox.com)
MAPBOX_ACCESS_TOKEN=pk.xxxxxxxxxxxxxxxxxxxxxxxx
