# ============================================================
# ROOT — Monorepo: frontend (Flutter) + backend (Node.js)
# ============================================================

# ========================
# FRONTEND (Flutter/Dart)
# ========================

# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# IntelliJ / Android Studio
*.iml
*.ipr
*.iws
.idea/

# VS Code
# Biarkan tetap dapat di-commit jika launch.json tidak berisi token.
# .vscode/

# Flutter / Dart / Pub
**/doc/api/
**/ios/Flutter/.last_build_id
frontend/.dart_tool/
frontend/.flutter-plugins
frontend/.flutter-plugins-dependencies
frontend/.pub-cache/
frontend/.pub/
frontend/build/
frontend/coverage/

# Symbolication dan obfuscation
app.*.symbols
app.*.map.json

# Android build artifacts
frontend/android/app/debug/
frontend/android/app/profile/
frontend/android/app/release/

# Environment lokal frontend
frontend/env.local.json
frontend/env.*.json
frontend/.env
frontend/.env.*
frontend/*.env

# File contoh frontend tetap boleh masuk Git
!frontend/.env.example
!frontend/env.example.json

# ========================
# BACKEND (Node.js)
# ========================

# Dependencies
backend/node_modules/

# Environment variables
backend/.env
backend/.env.*
backend/*.env
backend/.env-backup
backend/*.env-backup

# File contoh backend tetap boleh masuk Git
!backend/.env.example

# Logs
backend/logs/
backend/*.log
backend/npm-debug.log*
backend/yarn-debug.log*
backend/yarn-error.log*

# Build output
backend/dist/
backend/build/

# Runtime data
backend/pids/
backend/*.pid
backend/*.seed
backend/*.pid.lock

# Coverage
backend/coverage/

# Cache
backend/.npm/
backend/.eslintcache

# ========================
# ENVIRONMENT ROOT
# ========================

.env
.env.*
*.env-backup
.env-backup

# File contoh root tetap boleh masuk Git
!.env.example

# ========================
# SISTEM OPERASI
# ========================

.DS_Store
Thumbs.db
desktop.ini